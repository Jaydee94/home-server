# ANSIBLE MANAGED — scanner role
# Sourced by scan_button.sh and scan_to_pdf.sh to send Gotify pushes.
# Mode 0640, owned by root:scanner — readable for saned via the scanner group.
GOTIFY_ENABLED={{ scanner_gotify_enabled | ternary('1', '0') }}
GOTIFY_URL={{ scanner_gotify_url }}
GOTIFY_TOKEN={{ scanner_gotify_token }}
GOTIFY_PRIORITY_SUCCESS={{ scanner_gotify_priority_success }}
GOTIFY_PRIORITY_ERROR={{ scanner_gotify_priority_error }}
GOTIFY_TIMEOUT={{ scanner_gotify_timeout_seconds }}
