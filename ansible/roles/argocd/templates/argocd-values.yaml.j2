global:
  domain: argocd.{{ hostname }}

server:
  insecure: {{ argocd_server_insecure | lower }}
  service:
    type: NodePort
    nodePortHttp: 30080
    nodePortHttps: 30443

configs:
  cm:
    accounts.readonly: apiKey
  rbac:
    policy.csv: |
      g, readonly, role:readonly
  params:
    server.insecure: "{{ argocd_server_insecure | lower }}"

redis-ha:
  enabled: false

controller:
  replicas: 1

repoServer:
  replicas: 1

applicationSet:
  replicas: 1
