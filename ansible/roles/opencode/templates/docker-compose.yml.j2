# OpenCode Docker Compose deployment
# Generated by Ansible
# Upstream: https://github.com/jmt-labs/opencode/blob/main/compose.yaml
#
# Start:  docker compose -f {{ opencode_install_dir }}/docker-compose.yml up -d
# Stop:   docker compose -f {{ opencode_install_dir }}/docker-compose.yml down
# Logs:   docker compose -f {{ opencode_install_dir }}/docker-compose.yml logs -f

services:
  opencode:
    image: "{{ opencode_image }}:{{ opencode_version }}"
    container_name: "{{ opencode_container_name }}"
    restart: unless-stopped
    ports:
      - "{{ opencode_bind_addr }}:{{ opencode_port }}:4096"
    volumes:
      - "{{ opencode_persist_dir }}:/persist"
    environment:
      OPENCODE_GIT_REPO: "{{ opencode_git_repo | default('', true) }}"
      OPENCODE_GIT_REF: "{{ opencode_git_ref | default('main', true) }}"
      OPENCODE_GIT_USERNAME: "{{ opencode_git_username | default('', true) }}"
      OPENCODE_GIT_PASSWORD: "{{ opencode_git_password | default('', true) }}"
      GITHUB_TOKEN: "{{ opencode_github_token | default('', true) }}"
      GH_TOKEN: "{{ opencode_github_token | default('', true) }}"
      OPENCODE_AGENT_CONFIG_ENABLED: "{{ opencode_agent_config_enabled | ternary('true', 'false') }}"
      OPENCODE_BOOTSTRAP_PROJECT_AI_CONFIG: "{{ opencode_bootstrap_project_ai_config | ternary('true', 'false') }}"
      OPENCODE_PROJECT_PROFILE: "{{ opencode_project_profile | default('mobile', true) }}"
      OPENCODE_ADMIN_MODE: "{{ opencode_admin_mode | ternary('true', 'false') }}"
      OPENCODE_SERVER_AUTH_ENABLED: "{{ opencode_server_auth_enabled | ternary('true', 'false') }}"
    pull_policy: never
