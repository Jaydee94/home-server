# Managed by Ansible — do not edit manually.
# Wildcard DNS für *.homeserver — hört nur auf der LAN-IP.
# Der Server selbst nutzt weiterhin systemd-resolved.

# Upstream DNS: Fritz!Box
no-resolv
server={{ network_gateway }}

# *.homeserver → dieser Server
address=/.homeserver/{{ network_static_ip }}

# Nur auf der LAN-IP lauschen (nicht 127.0.0.1 — das gehört systemd-resolved)
listen-address={{ network_static_ip }}
bind-interfaces

domain-needed
bogus-priv
