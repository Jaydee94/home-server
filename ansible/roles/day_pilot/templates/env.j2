# ============================================================
#  Day Pilot – Environment Configuration
# ============================================================

# -------------------------------------------------------
# General
# -------------------------------------------------------
APP_NAME={{ day_pilot_app_name }}
APP_TIMEZONE={{ day_pilot_timezone }}
DAILY_SUMMARY_TIME={{ day_pilot_daily_summary_time }}

# -------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------
POSTGRES_DB={{ day_pilot_postgres_db }}
POSTGRES_USER={{ day_pilot_postgres_user }}
POSTGRES_PASSWORD={{ day_pilot_postgres_password }}
DATABASE_URL=postgresql://{{ day_pilot_postgres_user }}:{{ day_pilot_postgres_password }}@db:5432/{{ day_pilot_postgres_db }}

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_URL=redis://cache:6379/0

# -------------------------------------------------------
# OpenAI
# -------------------------------------------------------
OPENAI_API_KEY={{ day_pilot_openai_api_key }}
OPENAI_MODEL={{ day_pilot_openai_model }}

# -------------------------------------------------------
# AI Provider & Model selection
# -------------------------------------------------------
AI_PROVIDER={{ day_pilot_ai_provider }}
AI_MODEL={{ day_pilot_ai_model }}

# -------------------------------------------------------
# GitHub Models (used when AI_PROVIDER=github)
# -------------------------------------------------------
GITHUB_TOKEN={{ day_pilot_github_token }}

# -------------------------------------------------------
# Weather
# -------------------------------------------------------
WEATHERAPI_API_KEY={{ day_pilot_weatherapi_api_key | default(day_pilot_openweathermap_api_key, true) }}
WEATHER_CITY={{ day_pilot_weather_city }}
WEATHER_UNITS={{ day_pilot_weather_units }}

# -------------------------------------------------------
# Google Calendar / Tasks / Contacts
# -------------------------------------------------------
GOOGLE_CREDENTIALS_JSON=/app/data/credentials.json
GOOGLE_TOKEN_JSON=/app/data/google_token.json

# -------------------------------------------------------
# Apple Calendar via CalDAV
# -------------------------------------------------------
CALDAV_URL={{ day_pilot_caldav_url }}
CALDAV_USERNAME={{ day_pilot_caldav_username }}
CALDAV_PASSWORD={{ day_pilot_caldav_password }}

# -------------------------------------------------------
# Push Notifications (ntfy.sh)
# -------------------------------------------------------
NTFY_SERVER={{ day_pilot_ntfy_server }}
NTFY_TOPIC={{ day_pilot_ntfy_topic }}
NTFY_TOKEN={{ day_pilot_ntfy_token }}

# -------------------------------------------------------
# Voice-control webhook
# -------------------------------------------------------
VOICE_WEBHOOK_SECRET={{ day_pilot_voice_webhook_secret }}
