services:
  # ---------------------------------------------------------------------------
  # PostgreSQL – primary data store
  # ---------------------------------------------------------------------------
  db:
    image: postgres:17-alpine
    container_name: day-pilot-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: "{{ day_pilot_postgres_db }}"
      POSTGRES_USER: "{{ day_pilot_postgres_user }}"
      POSTGRES_PASSWORD: "{{ day_pilot_postgres_password }}"
    volumes:
      - db-data:/var/lib/postgresql/data
    networks:
      - daypilot-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ day_pilot_postgres_user }} -d {{ day_pilot_postgres_db }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  # ---------------------------------------------------------------------------
  # Redis – job queue and cache
  # ---------------------------------------------------------------------------
  cache:
    image: redis:7-alpine
    container_name: day-pilot-cache
    restart: unless-stopped
    command: redis-server --save 60 1 --loglevel warning
    volumes:
      - cache-data:/data
    networks:
      - daypilot-net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  # ---------------------------------------------------------------------------
  # Backend – FastAPI application
  # ---------------------------------------------------------------------------
  backend:
    image: "{{ day_pilot_backend_image }}:{{ day_pilot_tag }}"
    container_name: day-pilot-backend
    restart: unless-stopped
    env_file: .env
    environment:
      - DATABASE_URL=postgresql://{{ day_pilot_postgres_user }}:{{ day_pilot_postgres_password }}@db:5432/{{ day_pilot_postgres_db }}
      - REDIS_URL=redis://cache:6379/0
    ports:
      - "{{ day_pilot_backend_port }}:8000"
    volumes:
      - "{{ day_pilot_base_dir }}/data:/app/data"
    depends_on:
      db:
        condition: service_healthy
      cache:
        condition: service_healthy
    networks:
      - daypilot-net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  # ---------------------------------------------------------------------------
  # Frontend – React PWA served via nginx
  # ---------------------------------------------------------------------------
  frontend:
    image: "{{ day_pilot_frontend_image }}:{{ day_pilot_tag }}"
    container_name: day-pilot-frontend
    restart: unless-stopped
    ports:
      - "{{ day_pilot_frontend_port }}:80"
    depends_on:
      backend:
        condition: service_started
    networks:
      - daypilot-net

networks:
  daypilot-net:
    driver: bridge

volumes:
  db-data:
  cache-data:
