# Vault password files — never commit these!
.vault-password
.vault_password
*.vault

# Host-specific vault files — must be encrypted before committing
ansible/host_vars/*/vault.yml
# Exception: NAS vault.yml is encrypted (ansible-vault) and required by the
# Semaphore-triggered run, which clones a fresh copy from GitHub main.
!ansible/host_vars/ugreen-nas/vault.yml

