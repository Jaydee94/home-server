---
exclude_paths:
  - .git/
  - argocd/

skip_list:
  # We deliberately use the upstream curl-pipe install method documented by k3s and helm.
  - command-instead-of-module
  - risky-shell-pipe

warn_list:
  - experimental
  # Roles deliberately use short, non-role-prefixed var names as a repo-wide
  # convention. Surface as a warning instead of failing CI; renaming ~60 vars
  # across every role is a separate refactor.
  - var-naming[no-role-prefix]
